// ===== CALCULADORAS =====
function calcJuros(){
  const P=parseFloat(document.getElementById('jc-inicial').value)||0;
  const A=parseFloat(document.getElementById('jc-mensal').value)||0;
  const r=parseFloat(document.getElementById('jc-taxa').value)/100;
  const n=parseInt(document.getElementById('jc-periodo').value)||1;
  if(r<=0&&A<=0&&P<=0)return;
  // M = P*(1+r)^n + A*[((1+r)^n - 1)/r]
  const fator=Math.pow(1+r,n);
  const montante=P*fator+(r>0?A*(fator-1)/r:A*n);
  const investido=P+(A*n);
  const juros=montante-investido;
  const retPct=investido>0?(juros/investido)*100:0;
  document.getElementById('jc-montante').textContent=fmt(montante);
  document.getElementById('jc-investido').textContent=fmt(investido);
  document.getElementById('jc-juros').textContent=fmt(juros);
  document.getElementById('jc-retorno-pct').textContent=fmtPct(retPct);
  // Chart
  const steps=Math.min(n,12);
  const stepSize=Math.ceil(n/steps);
  const vals=[];
  for(let i=stepSize;i<=n;i+=stepSize){
    const f=Math.pow(1+r,i);
    vals.push(P*f+(r>0?A*(f-1)/r:A*i));
  }
  const maxV=Math.max(...vals);
  const barsEl=document.getElementById('proj-bars-juros');
  barsEl.innerHTML=vals.map((v,i)=>`
    <div class="proj-bar-wrap">
      <div class="proj-bar${i===vals.length-1?' highlight':''}" style="height:${(v/maxV*76).toFixed(0)}px"></div>
      <span class="proj-bar-label">${(i+1)*stepSize}m</span>
    </div>`).join('');
  document.getElementById('res-juros').classList.add('show');
  document.getElementById('proj-juros').style.display='block';
}

function calcMeta(){
  const meta=parseFloat(document.getElementById('mt-meta').value)||0;
  const P=parseFloat(document.getElementById('mt-inicial').value)||0;
  const A=parseFloat(document.getElementById('mt-mensal').value)||0;
  const taxaAnual=parseFloat(document.getElementById('mt-taxa').value)||0;
  if(meta<=0||A<=0)return;
  const r=taxaAnual/100/12;
  let saldo=P,meses=0;
  while(saldo<meta&&meses<1200){saldo=saldo*(1+r)+A;meses++;}
  const anos=Math.floor(meses/12);
  const mesesRest=meses%12;
  const totalAportado=P+(A*meses);
  const juros=saldo-totalAportado;
  document.getElementById('mt-anos').textContent=anos+' anos'+( mesesRest?' e '+mesesRest+' mes(es)':'');
  document.getElementById('mt-meses').textContent=meses+' meses';
  document.getElementById('mt-aportado').textContent=fmt(totalAportado);
  document.getElementById('mt-juros').textContent=fmt(Math.max(0,juros));
  document.getElementById('res-meta').classList.add('show');
}

function calcPgto(){
  const renda=parseFloat(document.getElementById('pg-renda').value)||0;
  const taxaRet=parseFloat(document.getElementById('pg-taxa').value)||4;
  const capitalAtual=parseFloat(document.getElementById('pg-capital').value)||0;
  const rentabAnual=parseFloat(document.getElementById('pg-rentab').value)||12;
  const anos=parseFloat(document.getElementById('pg-anos').value)||20;
  if(renda<=0)return;
  // Patrimônio necessário pela regra: renda_mensal*12/taxa_retirada*100
  const patrim=(renda*12)/(taxaRet/100);
  const falta=Math.max(0,patrim-capitalAtual);
  const r=rentabAnual/100/12;
  const n=anos*12;
  // PMT = PV * r*(1+r)^n / ((1+r)^n - 1) → inverso: quanto preciso aportar
  const fator=Math.pow(1+r,n);
  const aporte=falta>0&&r>0?falta*r*fator/(fator-1):(falta/n);
  const rendaHoje=capitalAtual*(taxaRet/100)/12;
  document.getElementById('pg-patrim').textContent=fmt(patrim);
  document.getElementById('pg-falta').textContent=fmt(falta);
  document.getElementById('pg-aporte').textContent=fmt(aporte)+'/mês';
  document.getElementById('pg-renda-hoje').textContent=fmt(rendaHoje)+'/mês';
  document.getElementById('res-pgto').classList.add('show');
}

function calcCDI(){
  const valor=parseFloat(document.getElementById('cdi-valor').value)||0;
  const cdi=parseFloat(document.getElementById('cdi-taxa').value)||0;
  const pctCdi=parseFloat(document.getElementById('cdi-pct').value)||100;
  const prazoMeses=parseInt(document.getElementById('cdi-prazo').value)||12;
  const ir=parseFloat(document.getElementById('cdi-ir').value)||15;
  if(valor<=0||cdi<=0)return;
  const taxaEfetiva=(cdi*pctCdi/100)/100;
  const taxaMensal=Math.pow(1+taxaEfetiva,1/12)-1;
  const montanteBruto=valor*Math.pow(1+taxaMensal,prazoMeses);
  const rendBruto=montanteBruto-valor;
  const irVal=rendBruto*(ir/100);
  const rendLiquido=rendBruto-irVal;
  const montanteLiquido=valor+rendLiquido;
  document.getElementById('cdi-bruto').textContent=fmt(rendBruto);
  document.getElementById('cdi-ir-val').textContent=fmt(irVal);
  document.getElementById('cdi-liquido').textContent=fmt(rendLiquido);
  document.getElementById('cdi-montante').textContent=fmt(montanteLiquido);
  document.getElementById('res-cdi').classList.add('show');
}

// ===== DUPLICATE =====
function openDupModal(singleItem=false){
  selectedDupMonths=new Set();
  _dupSingleItem=singleItem?_dupSingleItem:null;
  const filterDiv=document.getElementById('dup-filter');
  const desc=document.getElementById('dup-modal-desc');
  if(_dupSingleItem){filterDiv.style.display='none';desc.textContent='Selecione os meses para copiar este item.';}
  else{filterDiv.style.display='flex';desc.textContent='Copie os lançamentos do mês atual. O ponto (•) indica que o mês já possui dados.';}
  const grid=document.getElementById('dup-months-grid');
  grid.innerHTML='';
  for(let i=0;i<12;i++){
    if(i===currentMonth)continue;
    const destData=loadData(currentYear,i);
    const hasData=destData.income.length>0||destData.expense.length>0;
    const btn=document.createElement('div');
    btn.className='month-check'+(hasData?' has-data':'');
    btn.textContent=MONTHS[i].substring(0,3);
    btn.dataset.month=i;
    btn.onclick=()=>{
      if(selectedDupMonths.has(i)){selectedDupMonths.delete(i);btn.classList.remove('selected');}
      else{selectedDupMonths.add(i);btn.classList.add('selected');}
    };
    grid.appendChild(btn);
  }
  document.getElementById('dup-modal').classList.add('open');
}

function closeDupModal(){document.getElementById('dup-modal').classList.remove('open');_dupSingleItem=null;}

function confirmDuplicate(){
  if(!selectedDupMonths.size){showToast('Selecione ao menos um mês','warn');return;}
  const sourceData=loadData();
  const filterVal=document.querySelector('input[name="dupFilter"]:checked')?.value||'fixed';
  let incomeItems=sourceData.income,expenseItems=sourceData.expense;
  if(_dupSingleItem){
    const{type,id}=_dupSingleItem;
    incomeItems=type==='income'?sourceData.income.filter(i=>i.id===id):[];
    expenseItems=type==='expense'?sourceData.expense.filter(i=>i.id===id):[];
  } else if(filterVal==='fixed'){
    incomeItems=sourceData.income.filter(i=>i.recorrente);
    expenseItems=sourceData.expense.filter(i=>i.expType==='fixo'||i.expType==='parcelado');
  }
  let count=0;
  selectedDupMonths.forEach(m=>{
    const destData=loadData(currentYear,m);
    incomeItems.forEach(item=>{destData.income.push({...item,id:Date.now()+Math.random()*1000});count++;});
    expenseItems.forEach(item=>{
      const newItem={...item,id:Date.now()+Math.random()*1000};
      if(newItem.expType==='parcelado'&&newItem.parcelas){
        newItem.parcelaAtual=(newItem.parcelaAtual||1)+1;
        if(newItem.parcelaAtual>newItem.parcelas)return;
      }
      destData.expense.push(newItem);count++;
    });
    saveData(destData,currentYear,m);
  });
  closeDupModal();
  const monthNames=[...selectedDupMonths].map(m=>MONTHS[m].substring(0,3)).join(', ');
  if(count>0)showToast(`${count} item(s) copiado(s) → ${monthNames}`,'success');
  else showToast('Nenhum item correspondeu ao filtro','warn');
}

document.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&!document.getElementById('dup-modal').classList.contains('open')){
    if(document.activeElement.id.startsWith('income'))addItem('income');
    else if(document.activeElement.id.startsWith('expense'))addItem('expense');
  }
  if(e.key==='Escape')closeDupModal();
});

render();
</script>
