<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Minhas Contas</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0d0f14; --surface:#161920; --surface2:#1e2230; --border:#2a2f42;
  --accent:#c8f064; --accent-dim:#a8d04a; --red:#ff5e5e; --red-dim:#cc4040;
  --blue:#5ec8ff; --orange:#ffaa5e; --purple:#c084fc;
  --text:#e8eaf2; --text-muted:#7a8099; --text-dim:#4a5070;
  --font-display:'DM Serif Display',serif;
  --font-mono:'DM Mono',monospace;
  --font-body:'Plus Jakarta Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:var(--font-body);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:40px 40px;opacity:.22;pointer-events:none;z-index:0;}
.container{max-width:1160px;margin:0 auto;padding:36px 24px;position:relative;z-index:1;}

/* HEADER */
header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:16px;}
.header-left h1{font-family:var(--font-display);font-size:2.4rem;color:var(--text);line-height:1;letter-spacing:-.02em;}
.header-left h1 span{color:var(--accent);font-style:italic;}
.header-left p{color:var(--text-muted);font-size:.8rem;margin-top:6px;font-family:var(--font-mono);letter-spacing:.05em;}
.header-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.month-nav{display:flex;align-items:center;gap:7px;}
.month-nav button{background:var(--surface2);border:1px solid var(--border);color:var(--text-muted);width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:.95rem;transition:all .15s;}
.month-nav button:hover{border-color:var(--accent);color:var(--accent);}
#current-month{font-family:var(--font-mono);font-size:.82rem;color:var(--text);min-width:110px;text-align:center;letter-spacing:.07em;text-transform:uppercase;}
.btn-dup-month{background:var(--surface2);border:1px solid var(--orange);color:var(--orange);border-radius:9px;font-family:var(--font-mono);font-size:.72rem;letter-spacing:.06em;padding:7px 13px;cursor:pointer;transition:all .15s;white-space:nowrap;}
.btn-dup-month:hover{background:rgba(255,170,94,.1);}

/* TABS */
.tabs{display:flex;gap:4px;margin-bottom:28px;background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:5px;}
.tab-btn{flex:1;background:none;border:none;color:var(--text-muted);font-family:var(--font-mono);font-size:.78rem;letter-spacing:.06em;padding:10px 8px;border-radius:10px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.tab-btn:hover{color:var(--text);background:var(--surface2);}
.tab-btn.active{background:var(--surface2);color:var(--text);border:1px solid var(--border);}
.tab-btn.active.tab-inv{color:var(--purple);border-color:var(--purple);}
.tab-content{display:none;}
.tab-content.active{display:block;}

/* SUMMARY */
.summary{display:grid;grid-template-columns:repeat(4,1fr);gap:13px;margin-bottom:28px;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:18px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.card.income::before{background:var(--accent);}
.card.expense::before{background:var(--red);}
.card.balance::before{background:var(--blue);}
.card.savings::before{background:var(--orange);}
.card.inv-card::before{background:var(--purple);}
.card-label{font-size:.67rem;font-family:var(--font-mono);color:var(--text-muted);letter-spacing:.12em;text-transform:uppercase;margin-bottom:9px;}
.card-value{font-family:var(--font-display);font-size:1.6rem;line-height:1;}
.card.income .card-value{color:var(--accent);}
.card.expense .card-value{color:var(--red);}
.card.balance .card-value{color:var(--blue);}
.card.savings .card-value{color:var(--orange);}
.card.inv-card .card-value{color:var(--purple);}
.card-sub{font-size:.68rem;color:var(--text-dim);margin-top:5px;font-family:var(--font-mono);}

/* BUDGET BAR */
.budget-bar-wrap{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:14px 18px;margin-bottom:28px;display:flex;align-items:center;gap:13px;}
.budget-bar-label{font-size:.68rem;font-family:var(--font-mono);color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;}
.budget-bar-track{flex:1;height:5px;background:var(--surface2);border-radius:99px;overflow:hidden;}
.budget-bar-fill{height:100%;border-radius:99px;background:var(--accent);transition:width .5s cubic-bezier(.4,0,.2,1),background .3s;width:0%;}
.budget-bar-pct{font-family:var(--font-mono);font-size:.8rem;color:var(--text);white-space:nowrap;min-width:36px;text-align:right;}

/* COLUMNS */
.columns{display:grid;grid-template-columns:1fr 1fr;gap:22px;}
.section-title{font-family:var(--font-display);font-size:1.15rem;margin-bottom:13px;display:flex;align-items:center;gap:9px;}
.section-title .dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.income-section .dot{background:var(--accent);}
.expense-section .dot{background:var(--red);}

/* FORM */
.add-form{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:14px;margin-bottom:13px;display:flex;flex-direction:column;gap:9px;}
.form-row{display:flex;gap:7px;align-items:center;}
input[type="text"],input[type="number"],select{background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--font-body);font-size:.82rem;padding:8px 11px;outline:none;transition:border-color .15s;width:100%;}
input:focus,select:focus{border-color:var(--accent);}
select option,select optgroup{background:#1e2230;}
.btn-add-income,.btn-add-expense{border:none;border-radius:8px;font-family:var(--font-mono);font-size:.73rem;letter-spacing:.05em;padding:8px 14px;cursor:pointer;transition:all .15s;white-space:nowrap;font-weight:600;flex-shrink:0;}
.btn-add-income{background:var(--accent);color:#0d0f14;}
.btn-add-income:hover{background:var(--accent-dim);}
.btn-add-expense{background:var(--red);color:#fff;}
.btn-add-expense:hover{background:var(--red-dim);}
.note-input{color:var(--text-muted)!important;font-style:italic;}

/* ITEMS */
.items-list{display:flex;flex-direction:column;gap:6px;max-height:460px;overflow-y:auto;padding-right:2px;}
.items-list::-webkit-scrollbar{width:3px;}
.items-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px;}
.item{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 13px;display:flex;justify-content:space-between;align-items:center;animation:slideIn .2s ease;gap:7px;}
.item.fixo{border-left:2px solid var(--orange);}
.item.parcelado{border-left:2px solid var(--blue);}
.item.recorrente-item{border-left:2px solid var(--accent);}
@keyframes slideIn{from{opacity:0;transform:translateY(-5px);}to{opacity:1;transform:translateY(0);}}
.item-left{display:flex;align-items:center;gap:7px;min-width:0;flex:1;}
.item-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.78rem;flex-shrink:0;}
.item-icon.income-icon{background:rgba(200,240,100,.1);}
.item-icon.expense-icon{background:rgba(255,94,94,.1);}
.item-info{min-width:0;flex:1;}
.item-name{font-size:.83rem;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.item-meta{display:flex;gap:5px;align-items:center;flex-wrap:wrap;margin-top:2px;}
.item-cat{font-size:.64rem;color:var(--text-dim);font-family:var(--font-mono);}
.item-note{font-size:.63rem;color:var(--text-dim);font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:80px;}
.badge{font-size:.58rem;font-family:var(--font-mono);padding:1px 5px;border-radius:4px;}
.badge-fixed{background:rgba(255,170,94,.15);color:var(--orange);}
.badge-parcel{background:rgba(94,200,255,.15);color:var(--blue);}
.badge-rec{background:rgba(200,240,100,.12);color:var(--accent);}
.item-right{display:flex;align-items:center;gap:7px;flex-shrink:0;}
.item-value{font-family:var(--font-mono);font-size:.85rem;font-weight:500;}
.item-value.income-val{color:var(--accent);}
.item-value.expense-val{color:var(--red);}
.item-actions{display:flex;gap:3px;}
.item-btn{background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:.76rem;padding:3px 5px;border-radius:5px;transition:all .15s;}
.item-btn:hover{background:var(--surface2);}
.item-btn.del:hover{color:var(--red);}
.item-btn.dup-btn:hover{color:var(--orange);}
.empty-state{color:var(--text-dim);font-size:.76rem;font-family:var(--font-mono);text-align:center;padding:18px;border:1px dashed var(--border);border-radius:9px;}

/* CATEGORIES */
.cat-section{margin-top:28px;background:var(--surface);border:1px solid var(--border);border-radius:15px;padding:20px;}
.cat-section .section-title{margin-bottom:16px;}
.cat-bars{display:flex;flex-direction:column;gap:9px;}
.cat-bar-row{display:flex;align-items:center;gap:9px;}
.cat-bar-name{font-size:.72rem;font-family:var(--font-mono);color:var(--text-muted);width:115px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.cat-bar-track{flex:1;height:6px;background:var(--surface2);border-radius:99px;overflow:hidden;}
.cat-bar-fill{height:100%;border-radius:99px;background:var(--red);transition:width .5s cubic-bezier(.4,0,.2,1);}
.cat-bar-val{font-family:var(--font-mono);font-size:.72rem;color:var(--text-muted);width:80px;text-align:right;flex-shrink:0;}
.status-chip{display:inline-flex;align-items:center;gap:5px;font-size:.65rem;font-family:var(--font-mono);letter-spacing:.1em;padding:3px 7px;border-radius:99px;margin-top:4px;}
.status-chip.positive{background:rgba(200,240,100,.12);color:var(--accent);}
.status-chip.negative{background:rgba(255,94,94,.12);color:var(--red);}

/* ===================== INVESTMENTS TAB ===================== */
.inv-layout{display:grid;grid-template-columns:1fr 1fr;gap:22px;}
.inv-panel{background:var(--surface);border:1px solid var(--border);border-radius:15px;padding:20px;}
.inv-panel-title{font-family:var(--font-display);font-size:1.1rem;color:var(--purple);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.inv-panel-title .dot{width:7px;height:7px;border-radius:50%;background:var(--purple);flex-shrink:0;}

/* PORTFOLIO TABLE */
.portfolio-add{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;}
.portfolio-add .form-row input:focus,.portfolio-add .form-row select:focus{border-color:var(--purple);}
.btn-add-inv{border:none;border-radius:8px;font-family:var(--font-mono);font-size:.73rem;padding:8px 14px;cursor:pointer;background:var(--purple);color:#0d0f14;font-weight:700;flex-shrink:0;transition:all .15s;}
.btn-add-inv:hover{opacity:.85;}

.inv-list{display:flex;flex-direction:column;gap:6px;max-height:380px;overflow-y:auto;}
.inv-list::-webkit-scrollbar{width:3px;}
.inv-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px;}
.inv-item{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:11px 13px;display:flex;justify-content:space-between;align-items:center;gap:8px;}
.inv-item-left{flex:1;min-width:0;}
.inv-item-name{font-size:.84rem;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.inv-item-sub{font-size:.67rem;color:var(--text-muted);font-family:var(--font-mono);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap;}
.inv-item-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;}
.inv-item-value{font-family:var(--font-mono);font-size:.88rem;font-weight:600;color:var(--purple);}
.inv-item-return{font-family:var(--font-mono);font-size:.72rem;}
.inv-item-return.pos{color:var(--accent);}
.inv-item-return.neg{color:var(--red);}
.inv-item-actions{display:flex;gap:3px;margin-left:8px;}
.inv-item-btn{background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:.75rem;padding:3px 5px;border-radius:5px;transition:all .15s;}
.inv-item-btn:hover{background:var(--border);}
.inv-item-btn.edit-btn:hover{color:var(--purple);}
.inv-item-btn.del-btn:hover{color:var(--red);}

/* PORTFOLIO SUMMARY */
.inv-summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px;}
.inv-mini-card{background:var(--surface2);border:1px solid var(--border);border-radius:11px;padding:13px;}
.inv-mini-label{font-size:.65rem;font-family:var(--font-mono);color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px;}
.inv-mini-value{font-family:var(--font-display);font-size:1.35rem;line-height:1;}
.inv-mini-value.purple{color:var(--purple);}
.inv-mini-value.green{color:var(--accent);}
.inv-mini-value.red{color:var(--red);}
.inv-mini-value.orange{color:var(--orange);}
.inv-mini-sub{font-size:.65rem;color:var(--text-dim);font-family:var(--font-mono);margin-top:4px;}

/* ALLOCATION BARS */
.alloc-bars{display:flex;flex-direction:column;gap:8px;margin-top:4px;}
.alloc-row{display:flex;align-items:center;gap:8px;}
.alloc-name{font-size:.7rem;font-family:var(--font-mono);color:var(--text-muted);width:90px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.alloc-track{flex:1;height:6px;background:var(--surface);border-radius:99px;overflow:hidden;}
.alloc-fill{height:100%;border-radius:99px;transition:width .5s cubic-bezier(.4,0,.2,1);}
.alloc-pct{font-family:var(--font-mono);font-size:.68rem;color:var(--text-muted);width:38px;text-align:right;flex-shrink:0;}

/* ===================== CALCULATORS ===================== */
.calc-tabs{display:flex;gap:4px;margin-bottom:18px;}
.calc-tab{background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text-muted);font-family:var(--font-mono);font-size:.72rem;padding:7px 12px;cursor:pointer;transition:all .15s;}
.calc-tab:hover{color:var(--text);}
.calc-tab.active{border-color:var(--purple);color:var(--purple);background:rgba(192,132,252,.08);}
.calc-panel{display:none;}
.calc-panel.active{display:flex;flex-direction:column;gap:10px;}

.calc-field{display:flex;flex-direction:column;gap:4px;}
.calc-field label{font-size:.68rem;font-family:var(--font-mono);color:var(--text-muted);letter-spacing:.07em;}
.calc-field input,.calc-field select{background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--font-mono);font-size:.83rem;padding:8px 11px;outline:none;transition:border-color .15s;width:100%;}
.calc-field input:focus,.calc-field select:focus{border-color:var(--purple);}
.calc-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.btn-calc{background:var(--purple);border:none;border-radius:8px;color:#0d0f14;font-family:var(--font-mono);font-size:.78rem;font-weight:700;padding:10px;cursor:pointer;transition:all .15s;margin-top:4px;}
.btn-calc:hover{opacity:.85;}

.calc-result{background:var(--surface2);border:1px solid var(--border);border-radius:11px;padding:14px;margin-top:4px;display:none;}
.calc-result.show{display:block;}
.calc-result-title{font-size:.65rem;font-family:var(--font-mono);color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;}
.calc-result-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.calc-result-item{background:var(--surface);border-radius:8px;padding:10px;}
.calc-result-item label{font-size:.62rem;font-family:var(--font-mono);color:var(--text-dim);display:block;margin-bottom:3px;}
.calc-result-item .val{font-family:var(--font-mono);font-size:.92rem;font-weight:600;}
.calc-result-item .val.green{color:var(--accent);}
.calc-result-item .val.purple{color:var(--purple);}
.calc-result-item .val.orange{color:var(--orange);}
.calc-result-item .val.blue{color:var(--blue);}

/* PROJECTION CHART */
.proj-chart{margin-top:12px;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;}
.proj-chart-title{font-size:.65rem;font-family:var(--font-mono);color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;}
.proj-bars{display:flex;align-items:flex-end;gap:4px;height:80px;}
.proj-bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;}
.proj-bar{width:100%;border-radius:4px 4px 0 0;background:var(--purple);opacity:.7;transition:height .4s cubic-bezier(.4,0,.2,1);min-height:2px;}
.proj-bar.highlight{opacity:1;background:var(--accent);}
.proj-bar-label{font-size:.55rem;font-family:var(--font-mono);color:var(--text-dim);}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:100;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:26px;width:100%;max-width:420px;animation:modalIn .2s ease;}
@keyframes modalIn{from{opacity:0;transform:scale(.95) translateY(10px);}to{opacity:1;transform:scale(1) translateY(0);}}
.modal h3{font-family:var(--font-display);font-size:1.25rem;margin-bottom:7px;color:var(--orange);}
.modal p{font-size:.8rem;color:var(--text-muted);margin-bottom:16px;line-height:1.6;}
.modal-filter{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;}
.modal-filter label{display:flex;align-items:center;gap:6px;font-size:.75rem;font-family:var(--font-mono);color:var(--text-muted);cursor:pointer;background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 11px;transition:all .15s;}
.modal-filter label:hover{border-color:var(--orange);color:var(--text);}
.modal-filter input[type="radio"]{accent-color:var(--orange);}
.modal-months{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:18px;}
.month-check{display:flex;align-items:center;justify-content:center;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 5px;cursor:pointer;transition:all .15s;font-size:.73rem;font-family:var(--font-mono);color:var(--text-muted);text-align:center;position:relative;}
.month-check:hover{border-color:var(--orange);color:var(--text);}
.month-check.selected{border-color:var(--orange);background:rgba(255,170,94,.12);color:var(--orange);}
.month-check.has-data::after{content:'•';position:absolute;top:2px;right:4px;font-size:.5rem;color:var(--accent);}
.modal-actions{display:flex;gap:9px;justify-content:flex-end;}
.btn-cancel{background:none;border:1px solid var(--border);color:var(--text-muted);border-radius:8px;padding:8px 16px;cursor:pointer;font-family:var(--font-mono);font-size:.78rem;transition:all .15s;}
.btn-cancel:hover{border-color:var(--text-muted);}
.btn-confirm{background:var(--orange);border:none;color:#0d0f14;border-radius:8px;padding:8px 18px;cursor:pointer;font-family:var(--font-mono);font-size:.78rem;font-weight:700;transition:all .15s;}
.btn-confirm:hover{opacity:.85;}

/* EDIT MODAL */
.edit-modal h3{color:var(--purple);}

/* TOAST */
.toast{position:fixed;bottom:24px;right:24px;background:var(--surface2);border:1px solid var(--border);border-radius:11px;padding:11px 18px;font-family:var(--font-mono);font-size:.78rem;color:var(--text);z-index:200;opacity:0;transform:translateY(8px);transition:all .25s;pointer-events:none;}
.toast.show{opacity:1;transform:translateY(0);}
.toast.success{border-color:var(--accent);color:var(--accent);}
.toast.warn{border-color:var(--orange);color:var(--orange);}
.toast.error{border-color:var(--red);color:var(--red);}

@media(max-width:900px){.summary{grid-template-columns:repeat(2,1fr);}.columns,.inv-layout{grid-template-columns:1fr;}header{flex-direction:column;align-items:flex-start;}.header-left h1{font-size:1.9rem;}}
@media(max-width:480px){.summary{grid-template-columns:1fr;}.modal-months{grid-template-columns:repeat(3,1fr);}.inv-summary-grid,.calc-row,.calc-result-grid{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="container">

<header>
  <div class="header-left">
    <h1>Minhas <span>Contas</span></h1>
    <p>gestão financeira &amp; investimentos</p>
  </div>
  <div class="header-right">
    <button class="btn-dup-month" onclick="openDupModal()">⧉ Duplicar mês</button>
    <div class="month-nav">
      <button onclick="changeMonth(-1)">‹</button>
      <span id="current-month"></span>
      <button onclick="changeMonth(1)">›</button>
    </div>
  </div>
