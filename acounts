}

function switchCalc(id,btn){
  document.querySelectorAll('.calc-panel').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.calc-tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('calc-'+id).classList.add('active');
  btn.classList.add('active');
}

function changeMonth(dir){
  currentMonth+=dir;
  if(currentMonth>11){currentMonth=0;currentYear++;}
  if(currentMonth<0){currentMonth=11;currentYear--;}
  render();
}

function toggleParcela(sel){
  document.getElementById('expense-parcelas').style.display=sel.value==='parcelado'?'block':'none';
