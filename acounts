// ===== CONTAS =====
function addItem(type){
  const nameEl=document.getElementById(`${type}-name`);
  const valueEl=document.getElementById(`${type}-value`);
  const catEl=document.getElementById(`${type}-cat`);
  const noteEl=document.getElementById(`${type}-note`);
  const name=nameEl.value.trim();
  const value=parseFloat(valueEl.value);
  const cat=catEl.value;
  const note=noteEl.value.trim();
  if(!name||isNaN(value)||value<=0){nameEl.style.borderColor='var(--red)';setTimeout(()=>nameEl.style.borderColor='',1000);nameEl.focus();return;}
  const data=loadData();
  const item={id:Date.now(),name,value,cat,note};
  if(type==='income'){
    const recurEl=document.getElementById('income-recur');
    item.recorrente=recurEl.value==='recorrente';
    recurEl.value='';
  }
  if(type==='expense'){
    const typeEl=document.getElementById('expense-type');
    item.expType=typeEl.value;
    if(item.expType==='parcelado'){
      const parc=parseInt(document.getElementById('expense-parcelas').value)||1;
      item.parcelas=parc;item.parcelaAtual=1;
      document.getElementById('expense-parcelas').value='';
      document.getElementById('expense-parcelas').style.display='none';
    }
    typeEl.value='';
  }
  data[type].push(item);
  saveData(data);
  nameEl.value='';valueEl.value='';noteEl.value='';
  render();
}

function deleteItem(type,id){
  const data=loadData();
  data[type]=data[type].filter(i=>i.id!==id);
  saveData(data);render();
}

function openItemDup(type,id){_dupSingleItem={type,id};openDupModal(true);}

function renderList(type,items){
  const el=document.getElementById(`${type}-list`);
  if(!items.length){el.innerHTML=`<div class="empty-state">nenhum lançamento ainda</div>`;return;}
  el.innerHTML=items.map(item=>{
    const emoji=item.cat.split(' ')[0];
    const catName=item.cat.split(' ').slice(1).join(' ');
    let badges='',extraClass='';
    if(type==='income'&&item.recorrente){badges+=`<span class="badge badge-rec">🔁 recorrente</span>`;extraClass='recorrente-item';}
    if(type==='expense'){
      if(item.expType==='fixo'){badges+=`<span class="badge badge-fixed">📌 fixo</span>`;extraClass='fixo';}
      if(item.expType==='parcelado'){badges+=`<span class="badge badge-parcel">${item.parcelaAtual||1}/${item.parcelas||'?'}x</span>`;extraClass='parcelado';}
    }
    const noteHtml=item.note?`<span class="item-note" title="${item.note}">· ${item.note}</span>`:'';
    return `<div class="item ${extraClass}">
      <div class="item-left">
        <div class="item-icon ${type}-icon">${emoji}</div>
        <div class="item-info">
          <div class="item-name" title="${item.name}">${item.name}</div>
          <div class="item-meta"><span class="item-cat">${catName}</span>${badges}${noteHtml}</div>
        </div>
      </div>
      <div class="item-right">
        <span class="item-value ${type}-val">${fmt(item.value)}</span>
        <div class="item-actions">
          <button class="item-btn dup-btn" onclick="openItemDup('${type}',${item.id})" title="Copiar para outro mês">⧉</button>
          <button class="item-btn del" onclick="deleteItem('${type}',${item.id})" title="Remover">×</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function renderCats(expenses){
  const section=document.getElementById('cat-section');
  const barsEl=document.getElementById('cat-bars');
  if(!expenses.length){section.style.display='none';return;}
  section.style.display='block';
  const map={};
  expenses.forEach(e=>{const key=e.cat.split(' ').slice(1).join(' ')||e.cat;map[key]=(map[key]||0)+e.value;});
  const sorted=Object.entries(map).sort((a,b)=>b[1]-a[1]);
  const max=sorted[0][1];
  barsEl.innerHTML=sorted.map(([name,val])=>`
    <div class="cat-bar-row">
      <span class="cat-bar-name">${name}</span>
      <div class="cat-bar-track"><div class="cat-bar-fill" style="width:${(val/max*100).toFixed(1)}%"></div></div>
      <span class="cat-bar-val">${fmt(val)}</span>
    </div>`).join('');
}

function render(){
  document.getElementById('current-month').textContent=`${MONTHS[currentMonth]} ${currentYear}`;
  const data=loadData();
  const totalIncome=data.income.reduce((s,i)=>s+i.value,0);
  const totalExpense=data.expense.reduce((s,i)=>s+i.value,0);
  const bal=totalIncome-totalExpense;
  const savingsPct=totalIncome>0?Math.max(0,(bal/totalIncome)*100):0;
  document.getElementById('total-income').textContent=fmt(totalIncome);
  document.getElementById('income-count').textContent=`${data.income.length} lançamento${data.income.length!==1?'s':''}`;
  document.getElementById('total-expense').textContent=fmt(totalExpense);
  document.getElementById('expense-count').textContent=`${data.expense.length} lançamento${data.expense.length!==1?'s':''}`;
  document.getElementById('balance').textContent=fmt(bal);
  document.getElementById('savings-pct').textContent=savingsPct.toFixed(0)+'%';
  document.getElementById('savings-sub').textContent=bal>0?`${fmt(bal)} poupado`:'nada poupado este mês';
  const chip=document.getElementById('balance-chip');
  if(bal>0)chip.innerHTML=`<span class="status-chip positive">▲ no azul</span>`;
  else if(bal<0)chip.innerHTML=`<span class="status-chip negative">▼ déficit ${fmt(Math.abs(bal))}</span>`;
  else chip.innerHTML='';
  const pct=totalIncome>0?Math.min(100,(totalExpense/totalIncome*100)):(totalExpense>0?100:0);
  const bar=document.getElementById('budget-bar');
  bar.style.width=pct+'%';
  bar.style.background=pct>90?'var(--red)':pct>70?'#f0a000':'var(--accent)';
  document.getElementById('budget-pct').textContent=pct.toFixed(0)+'%';
  renderList('income',data.income);
  renderList('expense',data.expense);
  renderCats(data.expense);
}

